{
  "name": "crmcluster-website",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/crmcluster-website/src",
  "projectType": "application",
  "tags": ["scope:website"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "cache": true,
      "inputs": ["production", "^production"],
      "outputs": ["{projectRoot}/.next"],
      "options": {
        "cwd": "{projectRoot}",
        "command": "npx next build"
      }
    },
    "dev": {
      "executor": "nx:run-commands",
      "cache": false,
      "options": {
        "cwd": "{projectRoot}",
        "command": "npx next dev --port 3003"
      }
    },
    "start": {
      "executor": "nx:run-commands",
      "cache": false,
      "dependsOn": ["build"],
      "options": {
        "cwd": "{projectRoot}",
        "command": "npx next start --port 3003"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "command": "npx tsc --noEmit"
      }
    }
  }
}
